{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "0x00c0de-blog-append",
  "main": "src/index.js",
  "compatibility_date": "2026-03-31",
  "workers_dev": true,
  "durable_objects": {
    "bindings": [
      {
        "name": "VISITOR_COUNTER",
        "class_name": "VisitorCounter"
      },
      {
        "name": "RATE_LIMITER",
        "class_name": "RateLimiter"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "VisitorCounter"
      ]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": [
        "RateLimiter"
      ]
    }
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "ALLOWED_ORIGIN": "https://0x00c0de.github.io",
    "GITHUB_OWNER": "0x00C0DE",
    "GITHUB_REPO": "0x00C0DE.github.io",
    "GITHUB_BRANCH": "main",
    "GITHUB_BLOG_PATH": "blog.txt",
    "MAX_POST_LENGTH": "500",
    "MAX_IMAGE_DATA_URL_LENGTH": "100000000",
    "RATE_LIMIT_WINDOW_MS": "3600000",
    "RATE_LIMIT_MAX": "50"
  }
}
